[
  {
    "name": "goup_deploy_after_pull",
    "title": "GOUP EC2 Deploy After Pull",
    "description": "Commands to run after pulling new GOUP code on EC2.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "build_jobs": {
          "type": "integer",
          "default": 2,
          "minimum": 1,
          "maximum": 4,
          "description": "Cargo build job count for the EC2 release build."
        }
      },
      "additionalProperties": false
    },
    "output": {
      "text": "cd ~/goup.vc\ngit pull origin main\n\ncd ~/goup.vc/database/migrations\nTERN_CONF=\"$HOME/.config/ocg/tern.conf\" ./migrate.sh\n\ncd ~/goup.vc\nnohup env CARGO_BUILD_JOBS={{ build_jobs }} cargo build --release -p ocg-server > ~/goup-build.log 2>&1 &\ntail -f ~/goup-build.log\n\nsudo systemctl restart ocg-server\nsudo systemctl status ocg-server --no-pager\ncurl -I http://127.0.0.1:9000"
    }
  },
  {
    "name": "goup_run_migrations",
    "title": "GOUP Run Database Migrations",
    "description": "Run GOUP tern migrations on the configured database.",
    "inputSchema": {
      "type": "object",
      "properties": {},
      "additionalProperties": false
    },
    "output": {
      "text": "cd ~/goup.vc/database/migrations\nTERN_CONF=\"$HOME/.config/ocg/tern.conf\" ./migrate.sh"
    }
  },
  {
    "name": "goup_release_build_background",
    "title": "GOUP Background Release Build",
    "description": "Build the ocg-server release binary in the background and stream the log.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "build_jobs": {
          "type": "integer",
          "default": 2,
          "minimum": 1,
          "maximum": 4,
          "description": "Cargo build job count for the EC2 release build."
        }
      },
      "additionalProperties": false
    },
    "output": {
      "text": "cd ~/goup.vc\nnohup env CARGO_BUILD_JOBS={{ build_jobs }} cargo build --release -p ocg-server > ~/goup-build.log 2>&1 &\ntail -f ~/goup-build.log"
    }
  },
  {
    "name": "goup_service_status",
    "title": "GOUP Service Status",
    "description": "Check the deployed GOUP systemd service and local HTTP health.",
    "inputSchema": {
      "type": "object",
      "properties": {},
      "additionalProperties": false
    },
    "output": {
      "text": "sudo systemctl status ocg-server --no-pager\nsudo journalctl -u ocg-server -n 100 --no-pager\ncurl -I http://127.0.0.1:9000"
    }
  },
  {
    "name": "goup_create_event",
    "title": "GOUP Create Draft Event",
    "description": "Create an unpublished draft event in GOUP through the database add_event function. Requires MCP_ENABLE_MUTATIONS=true and database access through DATABASE_URL or TERN_CONF.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "actor_user_id": {
          "type": "string",
          "description": "User ID that should be recorded as the event creator."
        },
        "group_id": {
          "type": "string",
          "description": "Group ID where the event will be created."
        },
        "category_id": {
          "type": "string",
          "description": "Event category ID from the same alliance as the group."
        },
        "kind_id": {
          "type": "string",
          "enum": ["in-person", "virtual", "hybrid"],
          "description": "Event type."
        },
        "name": {
          "type": "string",
          "description": "Event name."
        },
        "description": {
          "type": "string",
          "description": "Full event description."
        },
        "description_short": {
          "type": "string",
          "description": "Optional short description for event cards."
        },
        "timezone": {
          "type": "string",
          "description": "IANA timezone, for example Asia/Baku."
        },
        "starts_at": {
          "type": "string",
          "description": "Local start datetime in the event timezone, for example 2026-07-01T18:00:00."
        },
        "ends_at": {
          "type": "string",
          "description": "Local end datetime in the event timezone, for example 2026-07-01T20:00:00."
        },
        "capacity": {
          "type": "integer",
          "description": "Optional attendee capacity."
        },
        "registration_required": {
          "type": "boolean",
          "description": "Whether attendees must register."
        },
        "attendee_approval_required": {
          "type": "boolean",
          "description": "Whether registrations require organizer approval."
        },
        "waitlist_enabled": {
          "type": "boolean",
          "description": "Whether the waitlist is enabled when capacity is full."
        },
        "meeting_join_url": {
          "type": "string",
          "description": "Optional manual meeting link."
        },
        "venue_name": {
          "type": "string",
          "description": "Optional venue name."
        },
        "venue_city": {
          "type": "string",
          "description": "Optional venue city."
        },
        "venue_country_name": {
          "type": "string",
          "description": "Optional venue country name."
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Optional event tags."
        }
      },
      "required": [
        "actor_user_id",
        "group_id",
        "category_id",
        "kind_id",
        "name",
        "description",
        "timezone",
        "starts_at",
        "ends_at"
      ],
      "additionalProperties": false
    },
    "action": "create_event"
  },
